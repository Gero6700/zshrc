# Copia este fichero a .env y ajusta lo que necesites.
# install.sh lo carga si existe; si no, usa los valores por defecto de aquí.

# Usuario para el que se instalan los dotfiles (zsh, oh-my-zsh, helix...).
# Por defecto se usa el usuario que invoca sudo (SUDO_USER). Solo hace falta
# fijarlo si vas a ejecutar el script como root directamente (sin sudo).
TARGET_USER=

# "base"  -> solo shell + Helix (zsh/p10k/CLI tools). Esto es lo que se
#            instala por defecto: nada de k8s/devops si no lo pides.
# "full"  -> lo de "base" + stack devops (kubectl, helm, k9s, terraform,
#            ansible, go, gh, yq, krew). Actívalo solo en las máquinas donde
#            realmente lo necesites.
INSTALL_PROFILE=base

# Canal (minor) del repositorio oficial de paquetes de Kubernetes.
K8S_CHANNEL=1.31

# Identidad de git a configurar globalmente para TARGET_USER.
# Déjalo en blanco para no tocar la configuración de git.
GIT_USER_NAME=
GIT_USER_EMAIL=
